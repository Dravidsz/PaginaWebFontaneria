---
export interface Props {
  name: string;
  location: string;
  rating: number;
  comment: string;
  service: string;
}

const { name, location, rating, comment, service } = Astro.props;
---

<div class="card flex flex-col h-full">
  <!-- Rating Stars -->
  <div class="flex items-center mb-4">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg 
        class={`w-5 h-5 ${i < rating ? 'text-yellow-400' : 'text-gray-300'}`} 
        fill="currentColor" 
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
      </svg>
    ))}
  </div>

  <!-- Comment -->
  <blockquote class="text-gray-700 mb-6 flex-grow italic">
    "{comment}"
  </blockquote>

  <!-- Service Badge -->
  <div class="mb-4">
    <span class="inline-block bg-primary-100 text-primary-800 text-sm font-medium px-3 py-1 rounded-full">
      {service}
    </span>
  </div>

  <!-- Author -->
  <div class="flex items-center border-t border-gray-100 pt-4">
    <div class="w-12 h-12 bg-primary-800 rounded-full flex items-center justify-center text-white font-bold text-lg">
      {name.charAt(0)}
    </div>
    <div class="ml-4">
      <div class="font-semibold text-gray-900">{name}</div>
      <div class="text-sm text-gray-500 flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        {location}
      </div>
    </div>
  </div>
</div>
