---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

import services from '../data/services.json';
import testimonials from '../data/testimonials.json';

const featuredTestimonials = testimonials.slice(0, 3);
---

<Layout title="Plomerías Panamá | Servicios Profesionales de Plomería">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <Hero />

    <!-- Services Section -->
    <section class="py-20 bg-white" id="servicios">
      <div class="container mx-auto px-4">
        <h2 class="section-title">Nuestros Servicios</h2>
        <p class="section-subtitle">
          Ofrecemos soluciones completas de plomería para hogares y negocios. 
          Cada servicio cuenta con garantía y atención personalizada.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {services.map((service) => (
            <ServiceCard 
              id={service.id}
              title={service.title}
              description={service.shortDescription}
              icon={service.icon}
            />
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/servicios" class="btn-primary">
            Ver todos los servicios
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="section-title">¿Por Qué Elegirnos?</h2>
        <p class="section-subtitle">
          Somos la opción preferida de miles de clientes en Panamá por nuestra calidad y compromiso.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Feature 1 -->
          <div class="text-center p-6">
            <div class="w-20 h-20 bg-primary-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Respuesta Rápida</h3>
            <p class="text-gray-600">Atendemos su emergencia el mismo día. Servicio ágil y eficiente.</p>
          </div>

          <!-- Feature 2 -->
          <div class="text-center p-6">
            <div class="w-20 h-20 bg-primary-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Trabajo Garantizado</h3>
            <p class="text-gray-600">Todos nuestros trabajos cuentan con garantía por escrito.</p>
          </div>

          <!-- Feature 3 -->
          <div class="text-center p-6">
            <div class="w-20 h-20 bg-primary-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Personal Capacitado</h3>
            <p class="text-gray-600">Técnicos certificados con años de experiencia en el campo.</p>
          </div>

          <!-- Feature 4 -->
          <div class="text-center p-6">
            <div class="w-20 h-20 bg-primary-800 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Precios Justos</h3>
            <p class="text-gray-600">Cotizaciones transparentes sin costos ocultos ni sorpresas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <h2 class="section-title">Lo Que Dicen Nuestros Clientes</h2>
        <p class="section-subtitle">
          La satisfacción de nuestros clientes es nuestra mejor carta de presentación.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredTestimonials.map((testimonial) => (
            <TestimonialCard 
              name={testimonial.name}
              location={testimonial.location}
              rating={testimonial.rating}
              comment={testimonial.comment}
              service={testimonial.service}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-primary-800 to-primary-900 text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          ¿Necesita un Plomero Profesional?
        </h2>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Contáctenos hoy mismo para una cotización gratuita. Estamos disponibles para atender su emergencia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contacto" class="btn-accent">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Solicitar Cotización
          </a>
          <a href="tel:+5076000000" class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-800 font-semibold rounded-lg hover:bg-gray-100 transition-colors duration-300">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Llamar Ahora
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>
