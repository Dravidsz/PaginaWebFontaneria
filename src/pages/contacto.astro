---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const contactInfo = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>`,
    title: "Teléfono",
    content: "+507 6000-0000",
    href: "tel:+5076000000"
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>`,
    title: "Email",
    content: "info@plomerias-panama.com",
    href: "mailto:info@plomerias-panama.com"
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>`,
    title: "Ubicación",
    content: "Ciudad de Panamá, Panamá",
    href: "#map"
  }
];

const services = [
  "Reparación de fugas",
  "Instalación de tuberías",
  "Destape de cañerías",
  "Calentadores de agua",
  "Remodelación de baños",
  "Instalación de grifería",
  "Otro servicio"
];
---

<Layout title="Contacto | Plomerías Panamá">
  <Header />
  
  <main>
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Contáctenos</h1>
        <p class="text-xl text-blue-100 max-w-2xl mx-auto">
          Estamos listos para atender su consulta. Solicite una cotización gratuita hoy mismo.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-20 bg-white">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Envíenos un Mensaje</h2>
            <form id="contact-form" class="space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                    Nombre Completo *
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                    placeholder="Su nombre"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                    Teléfono *
                  </label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone" 
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                    placeholder="+507 6000-0000"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Correo Electrónico
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder="su@email.com"
                />
              </div>

              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-2">
                  Servicio Requerido *
                </label>
                <select 
                  id="service" 
                  name="service" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors bg-white"
                >
                  <option value="">Seleccione un servicio</option>
                  {services.map((service) => (
                    <option value={service}>{service}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                  Descripción del Problema *
                </label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="5"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-none"
                  placeholder="Describa su problema o necesidad con el mayor detalle posible..."
                ></textarea>
              </div>

              <div>
                <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
                  Dirección (Opcional)
                </label>
                <input 
                  type="text" 
                  id="address" 
                  name="address"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder="Dirección donde se requiere el servicio"
                />
              </div>

              <button 
                type="submit" 
                class="w-full btn-primary justify-center py-4"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Enviar Mensaje
              </button>
            </form>

            <!-- Form Success Message (hidden by default) -->
            <div id="form-success" class="hidden mt-6 p-6 bg-green-50 border border-green-200 rounded-lg">
              <div class="flex items-center">
                <svg class="w-6 h-6 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h3 class="font-semibold text-green-800">¡Mensaje Enviado!</h3>
                  <p class="text-green-700 text-sm">Nos pondremos en contacto con usted pronto.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Información de Contacto</h2>
            
            <!-- Contact Cards -->
            <div class="space-y-4 mb-8">
              {contactInfo.map((info) => (
                <a 
                  href={info.href}
                  class="flex items-center p-4 bg-gray-50 rounded-lg hover:bg-primary-50 transition-colors group"
                >
                  <div class="w-12 h-12 bg-primary-800 rounded-lg flex items-center justify-center group-hover:bg-primary-700 transition-colors">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <Fragment set:html={info.icon} />
                    </svg>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm text-gray-500">{info.title}</div>
                    <div class="font-semibold text-gray-900 group-hover:text-primary-800 transition-colors">
                      {info.content}
                    </div>
                  </div>
                </a>
              ))}
            </div>

            <!-- WhatsApp CTA -->
            <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
              <div class="flex items-center mb-4">
                <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div class="ml-4">
                  <h3 class="font-bold text-gray-900">¿Prefiere WhatsApp?</h3>
                  <p class="text-sm text-gray-600">Respuesta inmediata garantizada</p>
                </div>
              </div>
              <a 
                href="https://wa.me/5076000000?text=Hola,%20me%20gustaría%20solicitar%20información%20sobre%20sus%20servicios%20de%20plomería."
                target="_blank"
                class="inline-flex items-center justify-center w-full px-6 py-3 bg-green-500 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors"
              >
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Escribir por WhatsApp
              </a>
            </div>

            <!-- Business Hours -->
            <div class="bg-gray-50 rounded-xl p-6">
              <h3 class="font-bold text-gray-900 mb-4 flex items-center">
                <svg class="w-5 h-5 mr-2 text-primary-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Horario de Atención
              </h3>
              <div class="space-y-2 text-gray-600">
                <div class="flex justify-between">
                  <span>Lunes - Viernes</span>
                  <span class="font-medium text-gray-900">7:00 AM - 6:00 PM</span>
                </div>
                <div class="flex justify-between">
                  <span>Sábado</span>
                  <span class="font-medium text-gray-900">8:00 AM - 2:00 PM</span>
                </div>
                <div class="flex justify-between">
                  <span>Domingo</span>
                  <span class="font-medium text-gray-500">Cerrado</span>
                </div>
                <div class="pt-3 mt-3 border-t border-gray-200">
                  <div class="flex items-center text-green-600">
                    <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
                    <span class="font-medium">Emergencias 24/7 disponibles</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section id="map" class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="section-title">Nuestra Ubicación</h2>
        <p class="section-subtitle">
          Servimos a toda la Ciudad de Panamá y áreas cercanas.
        </p>
        
        <!-- Map Placeholder -->
        <div class="bg-primary-100 rounded-2xl aspect-[21/9] flex items-center justify-center">
          <div class="text-center">
            <svg class="w-16 h-16 text-primary-800/50 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <p class="text-primary-800 font-medium">Mapa de Google Maps</p>
            <p class="text-primary-600 text-sm">Ciudad de Panamá, Panamá</p>
          </div>
        </div>
        <p class="text-center text-gray-500 text-sm mt-4">
          * Para integrar el mapa, reemplace este placeholder con un iframe de Google Maps.
        </p>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>

<script>
  // Simple form handling (for demo purposes)
  const form = document.getElementById('contact-form');
  const successMessage = document.getElementById('form-success');
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Simulate form submission
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.textContent = 'Enviando...';
      submitBtn.setAttribute('disabled', 'true');
    }
    
    setTimeout(() => {
      form.classList.add('hidden');
      successMessage?.classList.remove('hidden');
    }, 1500);
  });
</script>
